# App
# APP_PORT is optional on Railway; when omitted, the app uses Railway's PORT automatically.
APP_PORT=8080
APP_ENV=production
APP_RUNTIME_MODE=all
APP_SHUTDOWN_TIMEOUT_SECONDS=10
BUSINESS_TIMEZONE=Africa/Nairobi

# Database (Railway often provides DATABASE_URL)
# DB_URL=postgres://...
# Or: DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME

# Redis
REDIS_URL=redis://...
# REDIS_PASSWORD=
WHATSAPP_WEBHOOK_MAX_CONCURRENT=32
PAYMENT_DISPATCH_INTERVAL_MS=2100
PAYMENT_DISPATCH_POLL_INTERVAL_MS=250
ORDER_EXPIRY_SWEEP_INTERVAL_MS=5000
ORDERS_API_MAX_LIMIT=200

# WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Internal ops alerts
OPS_ALERT_PHONE=
# Legacy alias still supported:
# BAR_STAFF_PHONE=

# Dashboard
JWT_SECRET=
ALLOWED_ORIGIN=http://localhost:3000
# Comma-separated allowlist (preferred over ALLOWED_ORIGIN for multi-frontend support)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://mayas-pharm-admin.up.railway.app

# Kopo Kopo Payment Configuration
# Client ID + Secret for OAuth (token is fetched automatically)
KOPOKOPO_CLIENT_ID=
KOPOKOPO_CLIENT_SECRET=
# Webhook signing secret (used to verify X-KopoKopo-Signature header)
KOPOKOPO_WEBHOOK_SECRET=
KOPOKOPO_TILL_NUMBER=
KOPOKOPO_BASE_URL=https://api.kopokopo.com
# Full callback URL for payment webhooks (e.g., https://your-app.railway.app/api/webhooks/kopokopo)
KOPOKOPO_CALLBACK_URL=https://your-service.up.railway.app/api/webhooks/payment
# Optional: manual access token (e.g. sandbox token generator); if set, OAuth is not used
# KOPOKOPO_ACCESS_TOKEN=

# Pesapal hosted checkout (Airtel Money/Card)
# PESAPAL_CLIENT_ID=
# PESAPAL_CLIENT_SECRET=
# PESAPAL_ENVIRONMENT=production
# PESAPAL_IPN_URL=https://your-service.up.railway.app/api/webhooks/pesapal
# PESAPAL_IPN_TYPE=GET
# PESAPAL_NOTIFICATION_ID=
# PAYMENT_RETURN_URL=https://your-admin-or-status-page.up.railway.app/orders/status
